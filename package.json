{
  "name": "spvi-operation-audit",
  "version": "1.0.0",
  "description": "SPVi Operations Audit Toolkit",
  "main": "index.html",
  "scripts": {
    "dev": "node -e \"require('dotenv').config(); console.log('Environment loaded')\"",
    "start": "node server.js",
    "build": "echo 'Building for production...'",
    "test": "echo 'No tests specified'",
    "test:auth": "node server.js & sleep 2 && open http://localhost:3000/test-server-auth.html",
    "config:debug": "node -e \"require('dotenv').config(); console.log('Environment Variables:', Object.keys(process.env).filter(k => k.startsWith('FIREBASE_') || k.startsWith('GEMINI_') || k.startsWith('ADMIN_')))\""
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.2",
    "firebase-admin": "^13.4.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "repository": {
    "type": "git",
    "url": "."
  },
  "keywords": ["audit", "spvi", "operations", "firebase", "gemini"],
  "author": "SPVi Team",
  "license": "MIT"
}
